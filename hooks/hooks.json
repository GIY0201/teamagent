{
  "description": "teamagent: evidence-check (PostToolUse) + lifecycle-prune (SessionStart).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/evidence-check.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/lifecycle-prune.mjs\"",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
